<?xml version="1.0" encoding="utf-8"?>
<!--
  Azure App Service web.config for Next.js standalone
  Routes all traffic through the Node.js server
-->
<configuration>
  <system.webServer>
    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>
    <rewrite>
      <rules>
        <!-- Serve static files directly from .next/static -->
        <rule name="StaticNextFiles" stopProcessing="true">
          <match url="^_next/(.*)$" />
          <conditions>
            <add input="{DOCUMENT_ROOT}\.next\{R:1}" matchType="IsFile" />
          </conditions>
          <action type="Rewrite" url=".next/{R:1}" />
        </rule>
        <!-- All other requests → Node.js -->
        <rule name="DynamicContent">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>
    <iisnode
      node_env="%NODE_ENV%"
      nodeProcessCommandLine="node"
      interceptErrorCodes="false"
      enableXFF="true"
    />
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment=".next" />
          <add segment="node_modules" />
        </hiddenSegments>
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
